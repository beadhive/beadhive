# Copy to .env and fill in:  cp .env.example .env
# .env is gitignored — never commit real secrets. `just` auto-loads it (set dotenv-load),
# so bd also picks up BEADS_DOLT_PASSWORD from here.

# Admin password for the Dolt server (root@localhost).
DOLT_ROOT_PASSWORD=change-me-root

# Password for the 'beads' application user. bd reads this as BEADS_DOLT_PASSWORD.
BEADS_DOLT_PASSWORD=change-me-beads

# Application user + central database name (defaults are fine).
DOLT_USER=beads
DOLT_DATABASE=central

# Host port the server listens on (container is always 3306 internally).
DOLT_PORT=3307

# Where Dolt persists data on THIS host (bind mount).
# Local: keep the default. Homelab LXC: point at a dedicated dataset, e.g. /srv/beads/data
DOLT_DATA_DIR=./.dolt-data
