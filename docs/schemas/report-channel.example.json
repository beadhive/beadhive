{
  "$schema": "https://raw.githubusercontent.com/beadhive/beadhive/main/docs/schemas/report-channel.schema.json",
  "version": "1",
  "channels": [
    {
      "kind": "beads-rig",
      "target": "github/beadhive/beadhive",
      "verb": "ws report github/beadhive/beadhive \"<title>\"",
      "labels": ["intake:untriaged"]
    },
    {
      "kind": "github-issues",
      "target": "beadhive/beadhive",
      "verb": "gh issue create -R beadhive/beadhive"
    }
  ]
}
